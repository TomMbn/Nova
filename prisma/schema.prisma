// Schéma de données — Réseau social communautaire de l'école
// Basé sur le MCD final (voir doc de conception).
// La base Neon a été provisionnée directement à partir du DDL brut du MCD
// (contraintes nommées "xxx_foreign" / "xxx_unique"), pas via une migration
// Prisma. Ce schema.prisma reprend donc ces mêmes noms de contraintes
// (attributs `map`) pour que `prisma migrate diff` reste propre par rapport
// à la base réelle.
// Écarts assumés par rapport au MCD :
//  - ids en BigInt autoincrement (le MCD spécifie du BIGINT IDENTITY, Prisma
//    modélise ça avec @default(autoincrement()))
//  - `User.passwordHash` ajouté (hors MCD) pour l'auth Credentials existante
//  - les CHECK constraints du MCD (ex: message.sender_id <> receiver_id,
//    media.type IN (...)) ne sont pas exprimables dans le schema Prisma :
//    elles vivent dans la migration SQL mais pas ici

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  // "native" pour le dev local, "rhel-openssl-3.0.x" pour les fonctions
  // serverless Vercel (Amazon Linux 2023) — sans ça, le Query Engine binaire
  // n'est généré que pour la machine locale et le déploiement échoue au
  // runtime (PrismaClientInitializationError).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon : DATABASE_URL pointe sur le connection pooler (pgbouncer), qui ne
  // supporte pas les DDL/migrations → DIRECT_URL (connexion directe) est
  // utilisée par `prisma migrate`.
  directUrl = env("DIRECT_URL")
}

model Role {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "role_name_unique") @db.VarChar(50)

  users User[]

  @@map("role")
}

model Class {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "class_name_unique") @db.VarChar(100)

  users User[]

  @@map("class")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique(map: "user_email_unique") @db.VarChar(255)
  passwordHash String   @map("password_hash")
  name         String   @db.VarChar(255)
  bio          String?
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role   Role   @relation(fields: [roleId], references: [id], map: "user_role_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  roleId BigInt @map("role_id")

  currentClass   Class?  @relation(fields: [currentClassId], references: [id], map: "user_current_class_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  currentClassId BigInt? @map("current_class_id")

  posts              Post[]
  comments           Comment[]
  sentMessages       Message[]          @relation("MessageSender")
  receivedMessages   Message[]          @relation("MessageReceiver")
  followedTopics     FollowedTopic[]
  followedCategories FollowedCategory[]
  skills             UserSkill[]
  postLikes          PostLike[]
  bookmarks          Bookmark[]
  votes              Vote[]
  experiences        Experience[]
  registrations      FormationRegistration[]
  reviews            Review[]

  @@map("user")
}

model Topic {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "topic_name_unique") @db.VarChar(100)
  slug String @unique(map: "topic_slug_unique") @db.VarChar(100)

  posts           PostTopic[]
  followedBy      FollowedTopic[]
  formationVideos FormationVideoTopic[]
  formationSessions FormationSessionTopic[]

  @@map("topic")
}

model Category {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "category_name_unique") @db.VarChar(100)

  posts      Post[]
  followedBy FollowedCategory[]

  @@map("category")
}

model Skill {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "skill_name_unique") @db.VarChar(100)

  users UserSkill[]

  @@map("skill")
}

model Company {
  id   BigInt @id @default(autoincrement())
  name String @unique(map: "company_name_unique") @db.VarChar(255)

  experiences Experience[]

  @@map("company")
}

model Post {
  id        BigInt    @id @default(autoincrement())
  content   String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  eventDate DateTime? @map("event_date") @db.Timestamptz
  location  String?   @db.VarChar(255)

  author   User   @relation(fields: [authorId], references: [id], map: "post_author_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  authorId BigInt @map("author_id")

  category   Category @relation(fields: [categoryId], references: [id], map: "post_category_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  categoryId BigInt   @map("category_id")

  media     Media[]
  poll      Poll?
  comments  Comment[]
  topics    PostTopic[]
  likes     PostLike[]
  bookmarks Bookmark[]

  @@map("post")
}

// "type" : VARCHAR(20) + CHECK IN ('IMAGE', 'VIDEO') côté DB (MCD), validé
// applicativement plutôt qu'en enum Prisma pour matcher la base existante.
model Media {
  id       BigInt @id @default(autoincrement())
  type     String @db.VarChar(20)
  url      String @db.VarChar(500)
  position Int

  post   Post   @relation(fields: [postId], references: [id], map: "media_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId BigInt @map("post_id")

  @@map("media")
}

model Poll {
  id       BigInt @id @default(autoincrement())
  question String @db.VarChar(255)

  post   Post   @relation(fields: [postId], references: [id], map: "poll_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId BigInt @unique(map: "poll_post_id_unique") @map("post_id")

  options PollOption[]
  votes   Vote[]

  @@map("poll")
}

model PollOption {
  id    BigInt @id @default(autoincrement())
  label String @db.VarChar(255)

  poll   Poll   @relation(fields: [pollId], references: [id], map: "poll_option_poll_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  pollId BigInt @map("poll_id")

  votes Vote[]

  @@map("poll_option")
}

model Comment {
  id        BigInt   @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  author   User   @relation(fields: [authorId], references: [id], map: "comment_author_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  authorId BigInt @map("author_id")

  post   Post   @relation(fields: [postId], references: [id], map: "comment_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId BigInt @map("post_id")

  @@map("comment")
}

// CHECK ("sender_id" <> "receiver_id") côté MCD : à ajouter à la main dans la
// migration SQL, non représentable dans le schema Prisma.
model Message {
  id        BigInt    @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  readAt    DateTime? @map("read_at") @db.Timestamptz

  sender   User   @relation("MessageSender", fields: [senderId], references: [id], map: "message_sender_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  senderId BigInt @map("sender_id")

  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id], map: "message_receiver_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  receiverId BigInt @map("receiver_id")

  @@map("message")
}

model PostTopic {
  post    Post   @relation(fields: [postId], references: [id], map: "post_topic_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId  BigInt @map("post_id")
  topic   Topic  @relation(fields: [topicId], references: [id], map: "post_topic_topic_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  topicId BigInt @map("topic_id")

  @@id([postId, topicId])
  @@map("post_topic")
}

model FollowedTopic {
  user    User   @relation(fields: [userId], references: [id], map: "followed_topic_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId  BigInt @map("user_id")
  topic   Topic  @relation(fields: [topicId], references: [id], map: "followed_topic_topic_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  topicId BigInt @map("topic_id")

  @@id([userId, topicId])
  @@map("followed_topic")
}

model FollowedCategory {
  user       User     @relation(fields: [userId], references: [id], map: "followed_category_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId     BigInt   @map("user_id")
  category   Category @relation(fields: [categoryId], references: [id], map: "followed_category_category_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  categoryId BigInt   @map("category_id")

  @@id([userId, categoryId])
  @@map("followed_category")
}

model UserSkill {
  user    User   @relation(fields: [userId], references: [id], map: "user_skill_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId  BigInt @map("user_id")
  skill   Skill  @relation(fields: [skillId], references: [id], map: "user_skill_skill_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  skillId BigInt @map("skill_id")

  @@id([userId, skillId])
  @@map("user_skill")
}

model PostLike {
  user      User     @relation(fields: [userId], references: [id], map: "post_like_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId    BigInt   @map("user_id")
  post      Post     @relation(fields: [postId], references: [id], map: "post_like_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId    BigInt   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, postId])
  @@map("post_like")
}

model Bookmark {
  user      User     @relation(fields: [userId], references: [id], map: "bookmark_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId    BigInt   @map("user_id")
  post      Post     @relation(fields: [postId], references: [id], map: "bookmark_post_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  postId    BigInt   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, postId])
  @@map("bookmark")
}

model Vote {
  user     User       @relation(fields: [userId], references: [id], map: "vote_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId   BigInt     @map("user_id")
  option   PollOption @relation(fields: [optionId], references: [id], map: "vote_option_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  optionId BigInt     @map("option_id")
  poll     Poll       @relation(fields: [pollId], references: [id], map: "vote_poll_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  pollId   BigInt     @map("poll_id")

  @@id([userId, pollId])
  @@map("vote")
}

// ─── Espace Formations ────────────────────────────────────────────────────────

model FormationVideo {
  id          BigInt @id @default(autoincrement())
  title       String @db.VarChar(255)
  description String
  videoUrl    String @map("video_url") @db.VarChar(500)

  topics FormationVideoTopic[]

  @@map("formation_video")
}

model FormationSession {
  id          BigInt   @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String
  date        DateTime @db.Timestamptz
  location    String   @db.VarChar(255)
  // OPEN : inscriptions ouvertes ; DONE : session passée ; CANCELLED : annulée
  status      String   @default("OPEN") @db.VarChar(20)
  cpfUrl      String   @map("cpf_url") @db.VarChar(500)
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  // Débutant | Intermédiaire | Avancé
  level       String?  @db.VarChar(50)
  capacity    Int?

  registrations FormationRegistration[]
  reviews       Review[]
  topics        FormationSessionTopic[]

  @@map("formation_session")
}

model FormationVideoTopic {
  video   FormationVideo @relation(fields: [videoId], references: [id], map: "formation_video_topic_video_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  videoId BigInt         @map("video_id")
  topic   Topic          @relation(fields: [topicId], references: [id], map: "formation_video_topic_topic_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  topicId BigInt         @map("topic_id")

  @@id([videoId, topicId])
  @@map("formation_video_topic")
}

model FormationSessionTopic {
  session   FormationSession @relation(fields: [sessionId], references: [id], map: "formation_session_topic_session_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  sessionId BigInt           @map("session_id")
  topic     Topic            @relation(fields: [topicId], references: [id], map: "formation_session_topic_topic_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  topicId   BigInt           @map("topic_id")

  @@id([sessionId, topicId])
  @@map("formation_session_topic")
}

model FormationRegistration {
  id        BigInt   @id @default(autoincrement())
  status    String   @default("PENDING") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User             @relation(fields: [userId], references: [id], map: "formation_registration_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId    BigInt           @map("user_id")
  session   FormationSession @relation(fields: [sessionId], references: [id], map: "formation_registration_session_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  sessionId BigInt           @map("session_id")

  @@unique([userId, sessionId], map: "formation_registration_user_session_unique")
  @@map("formation_registration")
}

model Review {
  id        BigInt   @id @default(autoincrement())
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User             @relation(fields: [userId], references: [id], map: "review_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId    BigInt           @map("user_id")
  session   FormationSession @relation(fields: [sessionId], references: [id], map: "review_session_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  sessionId BigInt           @map("session_id")

  @@unique([userId, sessionId], map: "review_user_session_unique")
  @@map("review")
}

// ─── Fin Espace Formations ────────────────────────────────────────────────────

model Experience {
  id        BigInt    @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isCurrent Boolean   @default(false) @map("is_current")

  user   User   @relation(fields: [userId], references: [id], map: "experience_user_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  userId BigInt @map("user_id")

  company   Company @relation(fields: [companyId], references: [id], map: "experience_company_id_foreign", onDelete: NoAction, onUpdate: NoAction)
  companyId BigInt  @map("company_id")

  @@map("experience")
}
