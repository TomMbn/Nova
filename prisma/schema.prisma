// Schéma de données — Réseau social communautaire de l'école
// Basé sur le MCD final (voir doc de conception).
// Écarts assumés par rapport au MCD :
//  - ids en BigInt autoincrement (le MCD spécifie du BIGINT IDENTITY, Prisma
//    modélise ça avec @default(autoincrement()))
//  - `User.passwordHash` ajouté (hors MCD) pour l'auth Credentials existante
//  - `Media.type` modélisé en enum natif Postgres plutôt qu'en VARCHAR + CHECK
//  - les CHECK constraints du MCD (ex: message.sender_id <> receiver_id) ne
//    sont pas exprimables dans le schema Prisma : à ajouter à la main dans la
//    migration SQL générée si on veut les faire porter par la DB

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  IMAGE
  VIDEO
}

model Role {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  users User[]

  @@map("role")
}

model Class {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  users User[]

  @@map("class")
}

model User {
  id           BigInt   @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash")
  name         String   @db.VarChar(255)
  bio          String?
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role   Role   @relation(fields: [roleId], references: [id])
  roleId BigInt @map("role_id")

  currentClass   Class?  @relation(fields: [currentClassId], references: [id])
  currentClassId BigInt? @map("current_class_id")

  posts              Post[]
  comments           Comment[]
  sentMessages       Message[]          @relation("MessageSender")
  receivedMessages   Message[]          @relation("MessageReceiver")
  followedTopics     FollowedTopic[]
  followedCategories FollowedCategory[]
  skills             UserSkill[]
  postLikes          PostLike[]
  bookmarks          Bookmark[]
  votes              Vote[]
  experiences        Experience[]

  @@map("user")
}

model Topic {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  posts      PostTopic[]
  followedBy FollowedTopic[]

  @@map("topic")
}

model Category {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  posts      Post[]
  followedBy FollowedCategory[]

  @@map("category")
}

model Skill {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  users UserSkill[]

  @@map("skill")
}

model Company {
  id   BigInt @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  experiences Experience[]

  @@map("company")
}

model Post {
  id        BigInt    @id @default(autoincrement())
  content   String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  eventDate DateTime? @map("event_date") @db.Timestamptz
  location  String?   @db.VarChar(255)

  author   User   @relation(fields: [authorId], references: [id])
  authorId BigInt @map("author_id")

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId BigInt   @map("category_id")

  media     Media[]
  poll      Poll?
  comments  Comment[]
  topics    PostTopic[]
  likes     PostLike[]
  bookmarks Bookmark[]

  @@map("post")
}

model Media {
  id       BigInt    @id @default(autoincrement())
  type     MediaType
  url      String    @db.VarChar(500)
  position Int

  post   Post   @relation(fields: [postId], references: [id])
  postId BigInt @map("post_id")

  @@map("media")
}

model Poll {
  id       BigInt @id @default(autoincrement())
  question String @db.VarChar(255)

  post   Post   @relation(fields: [postId], references: [id])
  postId BigInt @unique @map("post_id")

  options PollOption[]
  votes   Vote[]

  @@map("poll")
}

model PollOption {
  id    BigInt @id @default(autoincrement())
  label String @db.VarChar(255)

  poll   Poll   @relation(fields: [pollId], references: [id])
  pollId BigInt @map("poll_id")

  votes Vote[]

  @@map("poll_option")
}

model Comment {
  id        BigInt   @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  author   User   @relation(fields: [authorId], references: [id])
  authorId BigInt @map("author_id")

  post   Post   @relation(fields: [postId], references: [id])
  postId BigInt @map("post_id")

  @@map("comment")
}

// CHECK ("sender_id" <> "receiver_id") côté MCD : à ajouter à la main dans la
// migration SQL, non représentable dans le schema Prisma.
model Message {
  id        BigInt    @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  readAt    DateTime? @map("read_at") @db.Timestamptz

  sender   User   @relation("MessageSender", fields: [senderId], references: [id])
  senderId BigInt @map("sender_id")

  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId BigInt @map("receiver_id")

  @@map("message")
}

model PostTopic {
  post    Post   @relation(fields: [postId], references: [id])
  postId  BigInt @map("post_id")
  topic   Topic  @relation(fields: [topicId], references: [id])
  topicId BigInt @map("topic_id")

  @@id([postId, topicId])
  @@map("post_topic")
}

model FollowedTopic {
  user    User   @relation(fields: [userId], references: [id])
  userId  BigInt @map("user_id")
  topic   Topic  @relation(fields: [topicId], references: [id])
  topicId BigInt @map("topic_id")

  @@id([userId, topicId])
  @@map("followed_topic")
}

model FollowedCategory {
  user       User     @relation(fields: [userId], references: [id])
  userId     BigInt   @map("user_id")
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId BigInt   @map("category_id")

  @@id([userId, categoryId])
  @@map("followed_category")
}

model UserSkill {
  user    User   @relation(fields: [userId], references: [id])
  userId  BigInt @map("user_id")
  skill   Skill  @relation(fields: [skillId], references: [id])
  skillId BigInt @map("skill_id")

  @@id([userId, skillId])
  @@map("user_skill")
}

model PostLike {
  user      User     @relation(fields: [userId], references: [id])
  userId    BigInt   @map("user_id")
  post      Post     @relation(fields: [postId], references: [id])
  postId    BigInt   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, postId])
  @@map("post_like")
}

model Bookmark {
  user      User     @relation(fields: [userId], references: [id])
  userId    BigInt   @map("user_id")
  post      Post     @relation(fields: [postId], references: [id])
  postId    BigInt   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@id([userId, postId])
  @@map("bookmark")
}

model Vote {
  user     User       @relation(fields: [userId], references: [id])
  userId   BigInt     @map("user_id")
  option   PollOption @relation(fields: [optionId], references: [id])
  optionId BigInt     @map("option_id")
  poll     Poll       @relation(fields: [pollId], references: [id])
  pollId   BigInt     @map("poll_id")

  @@id([userId, pollId])
  @@map("vote")
}

model Experience {
  id        BigInt    @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isCurrent Boolean   @default(false) @map("is_current")

  user   User   @relation(fields: [userId], references: [id])
  userId BigInt @map("user_id")

  company   Company @relation(fields: [companyId], references: [id])
  companyId BigInt  @map("company_id")

  @@map("experience")
}
