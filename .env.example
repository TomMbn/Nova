DATABASE_URL="postgresql://user:password@localhost:5432/mvp_workshop?schema=public"
# Sur Neon : connexion directe (non poolée), utilisée par `prisma migrate`.
# Avec une DB Postgres classique (non poolée), mettre la même valeur que DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/mvp_workshop?schema=public"
AUTH_SECRET="générer avec: openssl rand -base64 32"

# Photos de profil : stockage Vercel Blob. Créer un Blob Store dans le
# dashboard Vercel (Storage > Create Database > Blob) — le token est ensuite
# injecté automatiquement en prod ; en local, le copier depuis les Project
# Settings > Environment Variables.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
